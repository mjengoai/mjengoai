async function sendOTP(){
  const phone = document.getElementById('f-phone').value.trim();
  const fname = document.getElementById('f-fname').value.trim();
  const lname = document.getElementById('f-lname').value.trim();
  const err = document.getElementById('err-msg');
  if(!fname||!lname){err.style.display='flex';document.getElementById('err-text').textContent='Please enter your first and last name.';return;}
  if(!phone||phone.replace(/[^0-9]/g,'').length<7){err.style.display='flex';document.getElementById('err-text').textContent='Please enter a valid phone number.';return;}
  err.style.display='none';
  const digits = phone.replace(/[^0-9]/g,'');
  const formatted = digits.length===9?'+254'+digits:digits.length===10&&digits[0]==='0'?'+254'+digits.slice(1):digits.length>=12&&digits.startsWith('254')?'+'+digits:'+254'+digits.slice(-9);
  currentUser.name=fname+' '+lname;currentUser.phone=formatted;currentUser.role=currentRole;
  const btn=document.getElementById('btn-sendotp');
  btn.disabled=true;btn.textContent='Sending...';
  try{
    await initFirebase();
    const authMod=await import('https://www.gstatic.com/firebasejs/10.12.5/firebase-auth.js');
    if(window._mjDashReCap){try{window._mjDashReCap.clear();}catch(x){} window._mjDashReCap=null;}
    window._mjDashReCap=new authMod.RecaptchaVerifier(firebaseAuth,'mj-dash-recaptcha',{size:'invisible'});
    window._mjConfirmResult=await authMod.signInWithPhoneNumber(firebaseAuth,formatted,window._mjDashReCap);
    document.getElementById('otp-phone-disp').textContent=formatted;
    err.style.display='none';
    goStep(2);
  }catch(e){
    err.style.display='flex';
    document.getElementById('err-text').textContent=
      e.code==='auth/invalid-phone-number'?'Invalid number. Type 9 digits e.g. 712345678'
      :e.code==='auth/too-many-requests'?'Too many attempts. Please wait a few minutes.'
      :e.code==='auth/billing-not-enabled'?'Service temporarily unavailable. Please try again later.'
      :'Could not send code: '+e.message;
  }finally{btn.disabled=false;btn.textContent='Send WhatsApp Verification Code →';}
}
