async function subscribeDashboardData(role){
  if(roleDataUnsubscribe) roleDataUnsubscribe();
  if(!firebaseReady || !firebaseDb) return;
  const {doc,onSnapshot} = firebaseModules;
  roleDataUnsubscribe = onSnapshot(doc(firebaseDb,'dashboardRoles',role), snap=>{
    liveDashboardData[role] = snap.exists() ? snap.data() : {};
