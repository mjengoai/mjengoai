<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>MjengoAI – Sign Up & Dashboards</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=IM+Fell+English:ital@0;1&family=Nunito+Sans:opsz,wght@6..12,300;6..12,400;6..12,600;6..12,700;6..12,800&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#161614;--bg2:#1f1f1c;--bg3:#2a2a26;--bg4:#323230;
  --bdr:rgba(255,255,255,0.08);--bdr2:rgba(255,255,255,0.14);
  --text:#f0ede6;--muted:#888880;--muted2:#555550;
  --green:#7ec87e;--gd:#3a8c3a;--gdim:rgba(126,200,126,0.12);--gdim2:rgba(126,200,126,0.2);
  --gold:#c9952a;--gdim3:rgba(201,149,42,0.15);
  --blue:#4a7ec0;--bdim:rgba(74,126,192,0.14);
  --teal:#3aafb8;--orange:#e8a04a;--red:#d9534f;
  --serif:'IM Fell English',Georgia,serif;
  --sans:'Nunito Sans',sans-serif;
  --r:10px;--rl:16px;
  --shad:0 8px 32px rgba(0,0,0,0.6);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:var(--sans);background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}

/* ── PAGE TRANSITIONS ── */
.page{display:none;animation:fadeIn .28s ease;}
.page.active{display:flex;}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

/* ── NAV ── */
nav{display:flex;align-items:center;justify-content:space-between;padding:11px 28px;border-bottom:1px solid var(--bdr);position:sticky;top:0;background:rgba(22,22,20,0.96);backdrop-filter:blur(14px);z-index:300;}
.nlogo{display:flex;align-items:center;gap:9px;text-decoration:none;cursor:pointer;}
.nico{width:29px;height:29px;background:var(--gd);border-radius:7px;display:flex;align-items:center;justify-content:center;}
.ntxt{font-family:var(--serif);font-size:18px;color:var(--text);}
.nright{display:flex;align-items:center;gap:5px;}
.nlink{font-size:12px;color:var(--muted);text-decoration:none;padding:5px 9px;border-radius:6px;transition:all .18s;cursor:pointer;background:none;border:none;font-family:var(--sans);}
.nlink:hover{color:var(--text);background:rgba(255,255,255,0.06);}
.ncta{font-size:12px;font-weight:600;color:#fff;background:var(--gd);text-decoration:none;padding:6px 14px;border-radius:7px;transition:background .18s;margin-left:3px;cursor:pointer;border:none;font-family:var(--sans);}
.ncta:hover{background:#2d7a2d;}

/* ── LANDING CATEGORY SELECTOR ── */
#page-landing{flex-direction:column;min-height:100vh;}
.land-hero{max-width:780px;margin:0 auto;padding:52px 24px 32px;text-align:center;}
.hbadge{display:inline-flex;align-items:center;gap:6px;background:rgba(126,200,126,0.1);border:1px solid rgba(126,200,126,0.2);border-radius:20px;padding:4px 13px;font-size:11px;color:var(--green);margin-bottom:18px;letter-spacing:.04em;}
.hbadge b{width:5px;height:5px;border-radius:50%;background:var(--green);display:inline-block;}
.htitle{font-family:var(--serif);font-size:clamp(38px,6vw,64px);font-weight:400;color:var(--text);line-height:1.05;letter-spacing:-2px;margin-bottom:8px;}
.htitle em{font-style:italic;color:var(--green);}
.htag{font-size:13px;color:var(--muted);letter-spacing:.12em;text-transform:uppercase;margin-bottom:10px;}
.hjoin{font-size:14px;color:var(--muted);margin-bottom:38px;}

/* Category Cards Grid */
.cat-select-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;max-width:860px;margin:0 auto;padding:0 20px 48px;}
.cat-card{background:var(--bg2);border:1px solid var(--bdr);border-radius:var(--rl);padding:22px 18px;cursor:pointer;transition:all .22s;position:relative;overflow:hidden;text-align:left;}
.cat-card::before{content:'';position:absolute;inset:0;opacity:0;transition:opacity .22s;border-radius:var(--rl);}
.cat-card:hover{transform:translateY(-4px);border-color:var(--bdr2);box-shadow:var(--shad);}
.cat-card:hover::before{opacity:1;}
.cat-card.gc::before{background:radial-gradient(ellipse at top left,rgba(126,200,126,.16),transparent 70%);}
.cat-card.bc::before{background:radial-gradient(ellipse at top left,rgba(74,126,192,.16),transparent 70%);}
.cat-card.oc::before{background:radial-gradient(ellipse at top left,rgba(232,160,74,.16),transparent 70%);}
.cat-card.tc::before{background:radial-gradient(ellipse at top left,rgba(58,175,184,.14),transparent 70%);}
.cat-card.gc2::before{background:radial-gradient(ellipse at top left,rgba(201,149,42,.14),transparent 70%);}
.cat-card.rc::before{background:radial-gradient(ellipse at top left,rgba(217,83,79,.12),transparent 70%);}
.cico{width:44px;height:44px;border-radius:11px;display:flex;align-items:center;justify-content:center;margin-bottom:13px;font-size:22px;position:relative;z-index:1;}
.ctitle{font-size:14px;font-weight:700;color:var(--text);margin-bottom:4px;position:relative;z-index:1;}
.cdesc{font-size:11px;color:var(--muted);line-height:1.6;position:relative;z-index:1;}
.cbadge{display:inline-flex;align-items:center;gap:4px;margin-top:9px;font-size:10px;padding:2px 8px;border-radius:10px;position:relative;z-index:1;}
.cbadge.cg{background:var(--gdim);color:var(--green);}
.cbadge.cb{background:var(--bdim);color:#7ab4f0;}
.cbadge.co{background:var(--gdim3);color:var(--orange);}

/* ── AUTH PAGES ── */
#page-auth{flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:20px;}
.auth-wrap{width:100%;max-width:440px;}
.auth-back{display:flex;align-items:center;gap:7px;color:var(--muted);font-size:12px;cursor:pointer;margin-bottom:22px;transition:color .15s;background:none;border:none;font-family:var(--sans);padding:0;}
.auth-back:hover{color:var(--text);}
.auth-box{background:var(--bg2);border:1px solid var(--bdr2);border-radius:20px;padding:32px 30px;box-shadow:var(--shad);}
.auth-badge{display:flex;align-items:center;gap:9px;margin-bottom:20px;}
.auth-ico{width:42px;height:42px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.auth-cat{font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--muted);}
.auth-title{font-family:var(--serif);font-size:22px;color:var(--text);margin-bottom:5px;}
.auth-sub{font-size:12px;color:var(--muted);margin-bottom:24px;line-height:1.55;}

/* Tabs */
.auth-tabs{display:flex;background:var(--bg3);border-radius:10px;padding:3px;margin-bottom:22px;}
.atab{flex:1;padding:7px;text-align:center;font-size:12px;font-weight:600;color:var(--muted);cursor:pointer;border-radius:8px;transition:all .18s;border:none;background:none;font-family:var(--sans);}
.atab.on{background:var(--bg4);color:var(--text);}

/* Social logins */
.social-row{display:flex;gap:8px;margin-bottom:18px;}
.social-btn{flex:1;height:40px;background:var(--bg3);border:1px solid var(--bdr2);border-radius:9px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;font-size:12px;color:var(--text);font-family:var(--sans);transition:all .18s;}
.social-btn:hover{background:var(--bg4);border-color:rgba(255,255,255,0.2);}

/* Divider */
.divrow{display:flex;align-items:center;gap:10px;margin-bottom:18px;}
.divline{flex:1;height:1px;background:var(--bdr);}
.divtxt{font-size:11px;color:var(--muted2);}

/* Form */
.fgroup{margin-bottom:14px;}
.flabel{font-size:11px;font-weight:600;color:var(--muted);margin-bottom:5px;display:block;letter-spacing:.03em;}
.finput{width:100%;height:44px;background:var(--bg3);border:1px solid var(--bdr);border-radius:10px;padding:0 14px;font-family:var(--sans);font-size:13px;color:var(--text);outline:none;transition:border-color .18s,box-shadow .18s;}
.finput:focus{border-color:rgba(126,200,126,0.4);box-shadow:0 0 0 3px rgba(126,200,126,0.07);}
.finput::placeholder{color:var(--muted2);}
.frow{display:flex;gap:8px;}
.frow .fgroup{flex:1;}
.phone-wrap{display:flex;gap:0;}
.phone-pre{height:44px;padding:0 12px;background:var(--bg4);border:1px solid var(--bdr);border-right:none;border-radius:10px 0 0 10px;display:flex;align-items:center;font-size:13px;color:var(--muted);white-space:nowrap;flex-shrink:0;}
.phone-wrap .finput{border-radius:0 10px 10px 0;}

/* OTP */
.otp-row{display:flex;gap:8px;justify-content:center;margin:14px 0;}
.otpi{width:46px;height:52px;background:var(--bg3);border:1px solid var(--bdr);border-radius:10px;text-align:center;font-size:22px;font-weight:700;color:var(--text);outline:none;font-family:var(--sans);}
.otpi:focus{border-color:rgba(126,200,126,0.4);box-shadow:0 0 0 3px rgba(126,200,126,0.07);}

.fcta{width:100%;height:46px;background:var(--gd);border:none;border-radius:11px;color:#fff;font-size:14px;font-weight:700;cursor:pointer;font-family:var(--sans);transition:background .18s;margin-top:6px;}
.fcta:hover{background:#2d7a2d;}
.fcta:disabled{background:var(--bg4);color:var(--muted);cursor:default;}

.fhint{font-size:11px;color:var(--muted);text-align:center;margin-top:12px;line-height:1.55;}
.fhint a{color:var(--green);cursor:pointer;text-decoration:none;}

.fsuccess{background:var(--gdim);border:1px solid rgba(126,200,126,0.25);border-radius:10px;padding:12px 14px;font-size:12px;color:var(--green);display:flex;align-items:flex-start;gap:8px;margin-bottom:14px;}
.ferr{background:rgba(217,83,79,.1);border:1px solid rgba(217,83,79,.25);border-radius:10px;padding:12px 14px;font-size:12px;color:#e87878;display:flex;align-items:flex-start;gap:8px;margin-bottom:14px;}

/* select role visual */
.role-opts{display:flex;flex-direction:column;gap:7px;margin-bottom:16px;}
.role-opt{display:flex;align-items:center;gap:11px;background:var(--bg3);border:2px solid var(--bdr);border-radius:10px;padding:11px 14px;cursor:pointer;transition:all .15s;}
.role-opt.sel{border-color:var(--green);background:var(--gdim);}
.role-opt-ico{width:34px;height:34px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;}
.role-opt-txt{flex:1;}
.role-opt-name{font-size:12px;font-weight:700;color:var(--text);margin-bottom:1px;}
.role-opt-sub{font-size:10px;color:var(--muted);}
.role-opt-chk{width:18px;height:18px;border-radius:50%;border:2px solid var(--bdr2);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .15s;}
.role-opt.sel .role-opt-chk{background:var(--green);border-color:var(--green);color:#fff;font-size:10px;}

/* ── DASHBOARD ── */
#page-dash{flex-direction:column;min-height:100vh;}
.dash-layout{display:flex;flex:1;}

/* Sidebar */
.sidebar{width:220px;background:var(--bg2);border-right:1px solid var(--bdr);display:flex;flex-direction:column;min-height:calc(100vh - 53px);flex-shrink:0;position:sticky;top:53px;height:calc(100vh - 53px);overflow-y:auto;}
.sb-user{padding:18px 16px;border-bottom:1px solid var(--bdr);}
.sb-av{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;margin-bottom:9px;}
.sb-name{font-size:13px;font-weight:700;color:var(--text);margin-bottom:2px;}
.sb-role{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;}
.sb-nav{flex:1;padding:10px 10px;}
.sbi{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:8px;cursor:pointer;color:var(--muted);font-size:12px;font-weight:600;transition:all .15s;margin-bottom:2px;border:none;background:none;width:100%;text-align:left;font-family:var(--sans);}
.sbi:hover{color:var(--text);background:var(--bg3);}
.sbi.on{color:var(--text);background:var(--bg3);}
.sbi.on .sbi-dot{background:var(--green);}
.sbi-dot{width:5px;height:5px;border-radius:50%;background:transparent;flex-shrink:0;}
.sbi-ic{width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
.sb-section{font-size:9px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted2);padding:8px 10px 4px;font-weight:700;}
.sb-bottom{padding:12px 10px;border-top:1px solid var(--bdr);}

/* Main content */
.dash-main{flex:1;padding:22px 24px;overflow-y:auto;}
.dash-section{display:none;}
.dash-section.on{display:block;}

.dh{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;}
.dhtitle{font-family:var(--serif);font-size:22px;color:var(--text);letter-spacing:-.5px;}
.dhsub{font-size:12px;color:var(--muted);margin-top:2px;}
.dhbtn{padding:7px 16px;background:var(--gd);border:none;border-radius:8px;color:#fff;font-size:12px;font-weight:600;cursor:pointer;font-family:var(--sans);}

/* Stats row */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px;}
.stat-card{background:var(--bg2);border:1px solid var(--bdr);border-radius:var(--r);padding:14px;}
.stat-label{font-size:10px;color:var(--muted);letter-spacing:.04em;text-transform:uppercase;margin-bottom:6px;}
.stat-val{font-family:var(--serif);font-size:22px;color:var(--text);line-height:1;margin-bottom:3px;}
.stat-chg{font-size:10px;}
.stat-chg.up{color:#5cb85c;}.stat-chg.dn{color:#d9534f;}.stat-chg.nt{color:var(--muted);}

/* Grid 2 col */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px;}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:16px;}
.card{background:var(--bg2);border:1px solid var(--bdr);border-radius:var(--rl);padding:16px;}
.card-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:13px;}
.card-title{font-size:12px;font-weight:700;color:var(--text);}
.card-more{font-size:11px;color:var(--green);cursor:pointer;}

/* Activity list */
.act-item{display:flex;align-items:flex-start;gap:10px;padding:9px 0;border-bottom:1px solid var(--bdr);}
.act-item:last-child{border-bottom:none;}
.act-av{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;}
.act-body{flex:1;min-width:0;}
.act-name{font-size:12px;font-weight:600;color:var(--text);}
.act-sub{font-size:11px;color:var(--muted);margin-top:1px;}
.act-time{font-size:10px;color:var(--muted2);flex-shrink:0;margin-top:2px;}

/* Tags */
.tag{display:inline-flex;align-items:center;font-size:10px;padding:2px 8px;border-radius:5px;border:1px solid;}
.tg{background:rgba(126,200,126,.1);color:var(--green);border-color:rgba(126,200,126,.25);}
.tb{background:rgba(74,126,192,.1);color:#7ab4f0;border-color:rgba(74,126,192,.25);}
.to{background:rgba(232,160,74,.1);color:var(--orange);border-color:rgba(232,160,74,.25);}
.tgold{background:rgba(201,149,42,.1);color:#e8b84b;border-color:rgba(201,149,42,.25);}
.tr{background:rgba(217,83,79,.1);color:#e87878;border-color:rgba(217,83,79,.25);}

/* Progress bar */
.prog-wrap{margin-bottom:10px;}
.prog-label{display:flex;justify-content:space-between;font-size:11px;color:var(--muted);margin-bottom:5px;}
.prog{height:5px;background:var(--bg4);border-radius:3px;overflow:hidden;}
.progb{height:100%;border-radius:3px;transition:width .6s ease;}

/* File system */
.folder-row{display:flex;align-items:center;gap:10px;padding:9px 12px;background:var(--bg3);border-radius:8px;margin-bottom:6px;cursor:pointer;transition:background .14s;border:1px solid var(--bdr);}
.folder-row:hover{background:var(--bg4);}
.folder-ic{font-size:18px;}
.folder-name{font-size:12px;font-weight:600;color:var(--text);flex:1;}
.folder-cnt{font-size:10px;color:var(--muted);}
.folder-chev{font-size:11px;color:var(--muted);}

/* File item */
.file-item{display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:8px;cursor:pointer;transition:background .14s;}
.file-item:hover{background:var(--bg3);}
.file-ic{font-size:16px;}
.file-name{font-size:12px;color:var(--text);flex:1;}
.file-size{font-size:10px;color:var(--muted);}
.file-date{font-size:10px;color:var(--muted2);}

/* Upload zone */
.upload-zone{border:2px dashed var(--bdr2);border-radius:12px;padding:26px;text-align:center;cursor:pointer;transition:all .18s;margin-bottom:16px;}
.upload-zone:hover{border-color:rgba(126,200,126,0.4);background:rgba(126,200,126,0.03);}
.upload-zone-ic{font-size:30px;margin-bottom:8px;}
.upload-zone-t{font-size:13px;font-weight:600;color:var(--text);margin-bottom:3px;}
.upload-zone-s{font-size:11px;color:var(--muted);}

/* Storage bar */
.storage-bar{background:var(--bg3);border-radius:12px;padding:14px;margin-bottom:14px;}
.stor-hdr{display:flex;justify-content:space-between;font-size:11px;margin-bottom:8px;}
.stor-used{font-weight:600;color:var(--text);}
.stor-total{color:var(--muted);}

/* Profile form */
.profile-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.profile-av-section{display:flex;align-items:center;gap:16px;margin-bottom:22px;padding:18px;background:var(--bg3);border-radius:12px;}
.pav-big{width:64px;height:64px;border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:700;flex-shrink:0;}
.pav-info{flex:1;}
.pav-name{font-size:16px;font-weight:700;color:var(--text);margin-bottom:3px;}
.pav-role{font-size:11px;color:var(--muted);margin-bottom:8px;}
.pav-btn{padding:5px 14px;background:var(--bg4);border:1px solid var(--bdr2);border-radius:7px;font-size:11px;color:var(--text);cursor:pointer;font-family:var(--sans);}

/* Wallet card */
.wallet-card{background:linear-gradient(135deg,#0d3d1a 0%,#1a3a5c 100%);border:1px solid rgba(255,255,255,0.09);border-radius:16px;padding:22px;position:relative;overflow:hidden;margin-bottom:14px;}
.wallet-card::before{content:'MJT';position:absolute;right:-6px;top:-16px;font-family:var(--serif);font-size:90px;color:rgba(255,255,255,0.04);pointer-events:none;}
.wc-label{font-size:10px;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px;}
.wc-bal{font-family:var(--serif);font-size:28px;color:#fff;margin-bottom:3px;}
.wc-kes{font-size:12px;color:rgba(255,255,255,.5);margin-bottom:16px;}
.wc-row{display:flex;gap:8px;}
.wc-btn{flex:1;padding:8px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);border-radius:8px;font-size:11px;font-weight:600;color:#fff;cursor:pointer;font-family:var(--sans);transition:all .15s;}
.wc-btn:hover{background:rgba(255,255,255,.18);}
.wc-btn.pr{background:var(--gd);border-color:var(--gd);}

/* Rating stars */
.stars{color:var(--gold);font-size:12px;letter-spacing:1px;}

/* Badge */
.sbadge{display:inline-flex;align-items:center;gap:4px;font-size:9.5px;padding:2px 8px;border-radius:8px;}

/* Notifications dot */
.notif-dot{width:7px;height:7px;border-radius:50%;background:#d9534f;flex-shrink:0;}

/* Tender/job card */
.job-card{background:var(--bg3);border:1px solid var(--bdr);border-radius:10px;padding:12px;margin-bottom:8px;}
.jc-top{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;margin-bottom:7px;}
.jc-title{font-size:12px;font-weight:700;color:var(--text);}
.jc-meta{display:flex;align-items:center;gap:8px;margin-bottom:7px;}
.jc-loc{font-size:11px;color:var(--muted);display:flex;align-items:center;gap:3px;}
.jc-budget{font-size:12px;font-weight:600;color:var(--green);}
.jc-desc{font-size:11px;color:var(--muted);line-height:1.6;margin-bottom:8px;}
.jc-actions{display:flex;gap:6px;}
.jbtn{padding:5px 13px;border-radius:7px;font-size:11px;font-weight:600;cursor:pointer;font-family:var(--sans);transition:all .15s;border:1px solid;}
.jbtn.p{background:var(--gd);border-color:var(--gd);color:#fff;}
.jbtn.p:hover{background:#2d7a2d;}
.jbtn.s{background:transparent;border-color:var(--bdr2);color:var(--muted);}
.jbtn.s:hover{color:var(--text);background:var(--bg4);}

/* Msg thread */
.msg-item{display:flex;gap:10px;padding:10px 0;border-bottom:1px solid var(--bdr);}
.msg-item:last-child{border-bottom:none;}
.msg-av{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.msg-body{flex:1;min-width:0;}
.msg-hdr{display:flex;align-items:center;gap:8px;margin-bottom:2px;}
.msg-name{font-size:12px;font-weight:600;color:var(--text);}
.msg-time{font-size:10px;color:var(--muted2);}
.msg-prev{font-size:11px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.msg-unread{width:7px;height:7px;border-radius:50%;background:var(--green);flex-shrink:0;margin-top:3px;}

/* Plan browsing card */
.plan-card{background:var(--bg3);border:1px solid var(--bdr);border-radius:10px;overflow:hidden;cursor:pointer;transition:all .18s;}
.plan-card:hover{border-color:var(--bdr2);transform:translateY(-2px);}
.plan-thumb{height:100px;display:flex;align-items:center;justify-content:center;font-size:40px;background:var(--bg4);}
.plan-body{padding:10px;}
.plan-title{font-size:12px;font-weight:700;color:var(--text);margin-bottom:2px;}
.plan-sub{font-size:10px;color:var(--muted);margin-bottom:6px;}
.plan-price{font-size:12px;font-weight:600;color:var(--green);}

/* Responsive */
@media(max-width:860px){
  .cat-select-grid{grid-template-columns:repeat(2,1fr);}
  .stats-row{grid-template-columns:repeat(2,1fr);}
  .grid2,.profile-grid{grid-template-columns:1fr;}
  .sidebar{display:none;}
  .dash-main{padding:16px;}
}
@media(max-width:560px){
  .cat-select-grid{grid-template-columns:1fr 1fr;}
  .stats-row{grid-template-columns:1fr 1fr;}
  .grid3{grid-template-columns:1fr 1fr;}
}

/* Loader/spinner */
.spin{display:inline-block;width:16px;height:16px;border:2px solid rgba(255,255,255,.2);border-top-color:#fff;border-radius:50%;animation:sp .7s linear infinite;}
@keyframes sp{to{transform:rotate(360deg)}}

/* Tooltips / hints */
.hint-chip{display:inline-flex;align-items:center;gap:5px;background:var(--gdim3);border:1px solid rgba(201,149,42,.2);border-radius:20px;padding:3px 10px;font-size:10px;color:#e8b84b;margin-bottom:12px;}

/* verify step indicator */
.steps{display:flex;align-items:center;gap:0;margin-bottom:22px;}
.step{display:flex;flex-direction:column;align-items:center;flex:1;}
.step-circle{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;border:2px solid var(--bdr2);color:var(--muted);background:var(--bg3);transition:all .2s;}
.step-circle.done{background:var(--gd);border-color:var(--gd);color:#fff;}
.step-circle.active{border-color:var(--green);color:var(--green);background:var(--gdim);}
.step-line{flex:1;height:2px;background:var(--bdr);transition:background .2s;}
.step-line.done{background:var(--gd);}
.step-label{font-size:9px;color:var(--muted);margin-top:4px;text-align:center;}
.step-label.active{color:var(--green);}

/* whatsapp hint */
.wa-hint{display:flex;align-items:center;gap:8px;background:rgba(37,211,102,.08);border:1px solid rgba(37,211,102,.2);border-radius:9px;padding:10px 12px;margin-bottom:14px;font-size:11px;color:#4cdc86;}

/* Scrollbar */
::-webkit-scrollbar{width:5px;}::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:3px;}
