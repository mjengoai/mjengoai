}

/* ─── CONTRACTOR: TENDERS ─── */
function buildTenders(){
  return `<div class="dash-section" id="ds-tenders">
    <div class="dh"><div><div class="dhtitle">Tenders</div><div class="dhsub">Government &amp; private project opportunities</div></div></div>
    ${[{t:'Kiambu County — Road drainage works',b:'KES 8.5M',dead:'15 Jun 2025',tags:['Government','Infrastructure','PPRA']},{t:'NSSF Housing — 50 units Ruiru',b:'KES 45M',dead:'30 Jun 2025',tags:['Residential','NCA Class A']},{t:'Westlands Office Block — MEP Works',b:'KES 12M',dead:'20 Jun 2025',tags:['Commercial','MEP']}].map(j=>`
    <div class="job-card">
      <div class="jc-top"><div class="jc-title">${escapeHtml(j.t)}</div><div class="jc-budget">${escapeHtml(j.b)}</div></div>
      <div class="jc-meta"><span class="jc-loc">📅 Deadline: ${j.dead}</span>${j.tags.map(t=>`<span class="tag tgold" style="font-size:9px">${t}</span>`).join('')}</div>
      <div class="jc-actions"><button class="jbtn p">Download Tender Docs</button><button class="jbtn s">Save</button></div>
    </div>`).join('')}
  </div>`;
}

/* ─── CONTRACTOR: PROJECTS ─── */
function buildContractorProjects(){
  return `<div class="dash-section" id="ds-projects">
