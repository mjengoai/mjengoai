function goStep(n){
  document.getElementById('auth-step1').style.display = n===1?'block':'none';
  document.getElementById('auth-step2').style.display = n===2?'block':'none';
  [1,2,3].forEach(i=>{
    const c=document.getElementById('sc'+i);
    const l=document.getElementById('sl'+i);
    if(i<n){c.className='step-circle done';c.textContent='✓';l.className='step-label';}
    else if(i===n){c.className='step-circle active';c.textContent=i;l.className='step-label active';}
    else{c.className='step-circle';c.textContent=i;l.className='step-label';}
    if(i<3){const ln=document.getElementById('sline'+i);ln.className='step-line'+(i<n?' done':'');}
  });
}

