/* ─── SETTINGS ─── */
function buildSettings(){
  return `<div class="dash-section" id="ds-settings">
    <div class="dh"><div><div class="dhtitle">Settings</div></div></div>
    <div class="card" style="margin-bottom:12px">
      <div class="card-hdr"><div class="card-title">Notifications</div></div>
      ${[['WhatsApp alerts','New jobs and payments','on'],['Email digest','Weekly summary','on'],['Push notifications','Browser notifications','off']].map(([t,s,state])=>`
      <div class="act-item">
        <div class="act-body"><div class="act-name">${t}</div><div class="act-sub">${s}</div></div>
        <div style="width:40px;height:22px;border-radius:11px;background:${state==='on'?'var(--gd)':'var(--bg4)'};cursor:pointer;position:relative;transition:all .15s"><div style="width:18px;height:18px;border-radius:50%;background:#fff;position:absolute;top:2px;left:${state==='on'?'20px':'2px'};transition:left .15s"></div></div>
      </div>`).join('')}
    </div>
    <div class="card">
      <div class="card-hdr"><div class="card-title">Account</div></div>
      <div style="display:flex;flex-direction:column;gap:8px">
        <button class="jbtn s" style="text-align:left;justify-content:flex-start">🔒 Change Password</button>
        <button class="jbtn s" style="text-align:left;justify-content:flex-start">📱 Linked Devices</button>
        <button class="jbtn s" style="text-align:left;justify-content:flex-start;color:var(--red);border-color:rgba(217,83,79,.3)">⚠ Delete Account</button>
      </div>
    </div>
  </div>`;
}

