function escapeHtml(value){
  return String(value ?? '').replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
}

function safeDocId(value){
  return String(value || 'guest').replace(/[^\w-]/g,'_').slice(0,120);
}

