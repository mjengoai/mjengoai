      ${[['Portland Cement 50kg','KES 720','+2.1%'],['12mm Steel Rod','KES 1,350','+0.5%'],['Hollow Block 6"','KES 48','Stable'],['Gauge 30 Iron Sheet','KES 1,250','+5.0%']].map(([n,p,ch])=>`
      <div class="act-item">
        <div class="act-body"><div class="act-name">${n}</div><div class="act-sub">Market change: ${ch}</div></div>
