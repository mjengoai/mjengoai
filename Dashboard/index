      <div class="prog-wrap"><div class="prog-label"><span>Overall progress</span><span>${p.p}%</span></div><div class="prog"><div class="progb" style="width:${p.p}%;background:var(--orange)"></div></div></div>
      <div style="display:flex;gap:6px;margin-top:10px"><button class="jbtn p">Manage</button><button class="jbtn s">Site Reports</button><button class="jbtn s">Request Payment</button></div>
