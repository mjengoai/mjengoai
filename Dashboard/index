async function verifyOTP(){
  const code = [0,1,2,3,4,5].map(i=>{
    const el = document.getElementById('otp'+i);
    return el ? el.value : '';
  }).join('');
  if(code.replace(/[^0-9]/g,'').length < 6){ return; }

  const btn = document.querySelector('[onclick="verifyOTP()"]');
  if(btn){ btn.disabled=true; btn.textContent='Verifying...'; }

  try {
    if(window._mjConfirmResult){
      const result = await window._mjConfirmResult.confirm(code);
      const user = result.user;
      currentUser.uid = user.uid;
      currentUser.phone = user.phoneNumber || currentUser.phone;
    }
    /* Save locally always */
    localStorage.setItem('mjengoaiUser', JSON.stringify({...currentUser, updatedAt:new Date().toISOString()}));
    /* Save to Firestore non-blocking */
    if(firebaseDb && firebaseModules){
      try{
        const {doc,setDoc} = firebaseModules;
        const id = (currentUser.phone||currentUser.uid||'guest').replace(/[^a-zA-Z0-9_-]/g,'_');
        setDoc(doc(firebaseDb,'users',id),{name:currentUser.name,phone:currentUser.phone||'',role:currentUser.role,uid:currentUser.uid||'',joinedAt:new Date().toISOString()},{merge:true}).catch(e=>console.warn('[MjengoAI]',e.message));
        setDoc(doc(firebaseDb,'members',id),{name:currentUser.name,phone:currentUser.phone||'',role:currentUser.role,subCategory:currentUser.sub||'',active:false,verified:false,joinedAt:new Date().toISOString(),rating:0,reviews:0},{merge:true}).catch(e=>console.warn('[MjengoAI]',e.message));
      }catch(fe){console.warn('[MjengoAI] Firestore:',fe.message);}
    }
    goStep(3);
    setTimeout(launchDashboard, 500);
  } catch(e) {
    const errEl=document.getElementById('err-msg');
    const errTxt=document.getElementById('err-text');
    if(errEl) errEl.style.display='flex';
    if(errTxt) errTxt.textContent = e.code==='auth/invalid-verification-code'
      ? 'Wrong code. Please check and try again.'
      : e.code==='auth/code-expired' ? 'Code expired. Request a new one.'
      : 'Verification failed: '+e.message;
  } finally {
    if(btn){ btn.disabled=false; btn.textContent='Verify & Create Account'; }
  }
}

